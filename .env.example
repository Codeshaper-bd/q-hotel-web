# =============================================================================
# Q Hotel — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# All NUXT_ prefixed variables map to nuxt.config.ts runtimeConfig automatically.
# =============================================================================


# -----------------------------------------------------------------------------
# Site (public — visible to the browser)
# -----------------------------------------------------------------------------

NUXT_PUBLIC_SITE_URL=https://qhotel.com
NUXT_PUBLIC_SITE_NAME=Q Hotel


# -----------------------------------------------------------------------------
# Email / SMTP (private — server-only, used by contact form API route)
# Recommended providers: Resend, Postmark, SendGrid, or any SMTP relay.
# -----------------------------------------------------------------------------

# SMTP credentials
NUXT_SMTP_HOST=smtp.resend.com
NUXT_SMTP_PORT=465
NUXT_SMTP_SECURE=true
NUXT_SMTP_USER=resend
NUXT_SMTP_PASS=your-smtp-password-here

# Where contact form submissions are delivered
NUXT_CONTACT_RECIPIENT_EMAIL=info@qhotel.com
NUXT_CONTACT_SENDER_EMAIL=noreply@qhotel.com


# -----------------------------------------------------------------------------
# CMS (private — server-only, used for content fetching)
# Uncomment the block that matches your chosen CMS.
# -----------------------------------------------------------------------------

# --- Sanity ---
# NUXT_SANITY_PROJECT_ID=your-project-id
# NUXT_SANITY_DATASET=production
# NUXT_SANITY_API_TOKEN=your-read-token       # server-only, never expose
# NUXT_PUBLIC_SANITY_PROJECT_ID=your-project-id   # safe to expose
# NUXT_PUBLIC_SANITY_DATASET=production

# --- Contentful ---
# NUXT_CONTENTFUL_SPACE_ID=your-space-id
# NUXT_CONTENTFUL_ACCESS_TOKEN=your-delivery-token
# NUXT_CONTENTFUL_PREVIEW_TOKEN=your-preview-token

# --- Directus ---
# NUXT_DIRECTUS_URL=https://cms.qhotel.com
# NUXT_DIRECTUS_TOKEN=your-static-token


# -----------------------------------------------------------------------------
# Image CDN (used by @nuxt/image for remote image optimization)
# Only needed if serving images from an external host or CDN.
# -----------------------------------------------------------------------------

# NUXT_PUBLIC_IMAGE_CDN_URL=https://cdn.qhotel.com


# -----------------------------------------------------------------------------
# Analytics (public — safe to expose, loaded client-side)
# Only activate after cookie consent is implemented.
# -----------------------------------------------------------------------------

# --- Google Analytics 4 ---
# NUXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Plausible (privacy-friendly alternative) ---
# NUXT_PUBLIC_PLAUSIBLE_DOMAIN=qhotel.com

# --- Google Tag Manager ---
# NUXT_PUBLIC_GTM_ID=GTM-XXXXXXX


# -----------------------------------------------------------------------------
# Booking / Reservation Engine (private — server-only)
# Used when integrating a third-party booking system or channel manager.
# -----------------------------------------------------------------------------

# NUXT_BOOKING_API_URL=https://api.bookingengine.com
# NUXT_BOOKING_API_KEY=your-api-key
# NUXT_BOOKING_HOTEL_ID=your-hotel-id


# -----------------------------------------------------------------------------
# CAPTCHA / Spam Protection (for contact and reservation forms)
# Recommended: Google reCAPTCHA v3 or hCaptcha.
# -----------------------------------------------------------------------------

# --- reCAPTCHA v3 ---
# NUXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key    # browser
# NUXT_RECAPTCHA_SECRET_KEY=your-secret-key       # server-only verification

# --- hCaptcha ---
# NUXT_PUBLIC_HCAPTCHA_SITE_KEY=your-site-key
# NUXT_HCAPTCHA_SECRET_KEY=your-secret-key


# -----------------------------------------------------------------------------
# App / Runtime
# -----------------------------------------------------------------------------

# NODE_ENV is set automatically by the runtime — do not override manually.
# Use NUXT_PUBLIC_SITE_URL to control canonical URLs per environment.

# Port override (optional — default is 3000)
# PORT=3000
